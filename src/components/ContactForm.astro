---
const WEB_3_FORMS_KEY = import.meta.env.WEB_3_FORMS_KEY;
---

<form id="form" action="https://api.web3forms.com/submit" method="POST">
  <input type="hidden" name="access_key" value={WEB_3_FORMS_KEY} />
  <div class="small-inputs">
    <div>
      <label for="name">First Name</label>
      <input
        type="text"
        id="name"
        name="name"
        placeholder="First name"
        required
      />
    </div>

    <div>
      <label for="email">Email</label>
      <input
        id="email"
        type="email"
        name="email"
        inputmode="email"
        placeholder="Email Address"
        required
      />
    </div>
  </div>
  <div>
    <label for="message">Message</label>
    <textarea
      id="message"
      name="message"
      rows="6"
      placeholder="Message"
      required></textarea>
  </div>
  <button type="submit">Submit</button>
</form>

<style>
  form {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  input,
  textarea {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--nord3-polar-night);
    border-radius: 0.25rem;
    background-color: var(--nord0-polar-night);
    color: var(--nord4-snow-storm);
    font-weight: normal;
    transition: border 0.2s;
  }

  input:focus-visible,
  textarea:focus-visible {
    outline: none;
    border-color: var(--nord4-snow-storm);
  }

  input::placeholder,
  textarea::placeholder {
    color: #d8dee995;
    font-weight: 300;
  }

  textarea {
    width: 100%;
    box-sizing: border-box;
    resize: none;
  }

  button {
    font-family: "IBM Plex Mono";
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    width: 50%;
    background:;
    border: 1px solid var(--nord0-polar-night);
    border-radius: 0.25rem;
    margin: 0 auto;
    padding: 0.5rem 0.75rem;
    color: var(--nord0-polar-night);
    font-size: 1.25rem;
    font-weight: 700;
    cursor: pointer;
    background: var(--nord9-frost);
    transition: all 0.2s ease;
  }

  button:hover {
    color: var(--nord4-snow-storm);
    border: 1px solid var(--nord4-snow-storm);
    background: var(--nord10-frost);
  }

  .small-inputs {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .small-inputs > div {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  @media (min-width: 768px) {
    .small-inputs > div {
      width: calc(50% - 0.5rem);
    }
  }
</style>
