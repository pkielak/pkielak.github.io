---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import NetworkGraph from "../components/NetworkGraph";

const graph = await import("../pages/graph.json");
const graphData = await graph.GET({}).then((response) => response.json());

interface Props {
  title: string;
  description: string;
  isGraphSmall?: boolean;
}

const { title, description } = Astro.props;
const today = new Date();
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <div class="stars-wrapper">
      <div class="stars"></div>
      <div class="twinkling"></div>
    </div>
    <Header />
    <main>
      <slot />
    </main>

    <div class="controls-wrapper">
      <div id="tap-to-unlock" class="tap-to-unlock visible">
        Tap to unlock the graph
      </div>
      <button id="lock-graph" class="lock-graph"> Lock graph </button>
      <div id="graph-wrapper" class="graph-wrapper">
        <span class="zoom-control-text">Hold Ctrl + Scroll to Zoom</span>

        <NetworkGraph graphData={graphData} client:idle transition:persist />
      </div>
    </div>
    <footer>
      <span>
        &copy; {today.getFullYear()} pkielak | <a href="/privacy"
          >Privacy policy</a
        >
      </span>
    </footer>
  </body>
</html>

<style>
