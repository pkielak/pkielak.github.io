  .twinkling {
    width: 200vw;
    height: 100%;
    background: repeating-linear-gradient(
      to top left,
      #2e3440,
      #2e3440,
      transparent 5px,
      transparent 10px
    );
    background-size: 200vw 200vw;
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    z-index: 2;

    animation: move-background 70s linear infinite;
  }

  @keyframes move-background {
    from {
      -webkit-transform: translate3d(0px, 0px, 0px);
    }
    to {
      -webkit-transform: translate3d(1200px, 0px, 0px);
    }
  }

  @media (min-width: 768px) {
    .graph-wrapper {
      height: 100vh;
    }

    .tap-to-unlock {
      height: 100vh;
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .zoom-control-text {
      display: block;
    }

    .tap-to-unlock {
      display: none;
    }

    .lock-graph {
      display: none;
    }
  }
</style>

<script type="module" is:inline data-astro-rerun>
  (() => {
    function onUnlock(overlay, button) {
      overlay?.classList.toggle("visible");
      button?.classList.toggle("visible");
    }

    function init() {
      const tapToUnlock = document.getElementById("tap-to-unlock");
      const lockGraph = document.getElementById("lock-graph");

      [tapToUnlock, lockGraph].forEach((element) =>
        element.addEventListener("click", () =>
          onUnlock(tapToUnlock, lockGraph),
        ),
      );
    }
    init();
  })();
</script>
